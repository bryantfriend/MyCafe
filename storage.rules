rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isImage() {
      return request.resource != null
        && request.resource.contentType.matches('image/.*')
        && request.resource.size < 5 * 1024 * 1024;
    }

    match /cafes/{cafeId}/{folder}/{fileName} {
      allow read: if true;
      allow write: if signedIn() && isImage();
    }

    match /reviews/{reviewId}/{fileName} {
      allow read: if true;
      allow write: if signedIn() && isImage();
    }

    match /circles/{circleId}/{fileName} {
      allow read: if true;
      allow write: if signedIn() && isImage();
    }

    match /{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
